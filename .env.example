# =============================================================================
# FB Ad Accelerator Light — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
#   cp .env.example .env
# =============================================================================

# -- Required ------------------------------------------------------------------

# SQLite database file path (default: ./data/app.db)
# DATABASE_URL=./data/app.db

# OpenAI API key — used for AI-powered ad copy and image generation
OPENAI_API_KEY=

# -- Optional ------------------------------------------------------------------

# Server port (default: 3000)
# PORT=3000

# Node environment (development | production)
# NODE_ENV=development

# Custom OpenAI-compatible base URL (default: https://api.openai.com/v1)
# OPENAI_BASE_URL=

# JWT secret for signing session cookies (auto-generated if omitted in dev mode)
# JWT_SECRET=

# ---------- OAuth (optional — local login is used when not configured) --------

# OAuth application identifier
# VITE_APP_ID=

# OAuth portal URL (the login page users are redirected to)
# VITE_OAUTH_PORTAL_URL=

# OAuth server URL (backend token exchange endpoint)
# OAUTH_SERVER_URL=

# OpenID of the super-admin user (receives admin role automatically)
# OWNER_OPEN_ID=

# ---------- Analytics (optional — omit to disable Umami analytics) -----------

# Umami analytics endpoint URL (e.g. https://analytics.example.com)
# VITE_ANALYTICS_ENDPOINT=

# Umami website ID to track
# VITE_ANALYTICS_WEBSITE_ID=

# ---------- Manus Platform (only needed when running inside Manus) ------------

# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=
